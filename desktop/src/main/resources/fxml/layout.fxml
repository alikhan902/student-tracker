<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="student_tracker.controller.LayoutController"
            stylesheets="@layout.css">

    <children>
        <HBox fx:id="rootContainer" spacing="0"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
              styleClass="app-root">

            <fx:include source="sidebar.fxml" fx:id="sidebar"/>

            <BorderPane fx:id="contentWrapper" styleClass="content-wrapper"
                        HBox.hgrow="ALWAYS">
                <top>
                    <HBox fx:id="header" alignment="CENTER_LEFT" spacing="12"
                          styleClass="header">
                        <Button fx:id="menuButton" text="☰"
                                styleClass="menu-button"/>
                        <Label text="Student Tracker"
                               styleClass="header-title"/>
                    </HBox>
                </top>

                <center>
                    <ScrollPane fitToWidth="true" fitToHeight="true"
                                styleClass="main-scrollpane">
                        <content>
                            <VBox fx:id="mainContent" spacing="20"
                                  styleClass="main-content" 
                                  prefHeight="2000">
                                <!-- Здесь будет основной контент страницы -->
                            </VBox>
                        </content>
                    </ScrollPane>
                </center>
            </BorderPane>
        </HBox>
    </children>
</AnchorPane>