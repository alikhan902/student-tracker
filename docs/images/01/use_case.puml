User --> UC25

Headman --> UC06
Headman --> UC07
Headman --> UC08
Headman --> UC09
Headman --> UC10
Headman --> UC11
Headman --> UC12
Headman --> UC13
Headman --> UC14
Headman --> UC15
Headman --> UC16
Headman --> UC17
Headman --> UC18
Headman --> UC19
Headman --> UC20
Headman --> UC21
Headman --> UC22
Headman --> UC23
Headman --> UC24
Headman --> UC25

Auditor --> UC06
Auditor --> UC10
Auditor --> UC15
Auditor --> UC17
Auditor --> UC21

@enduml
